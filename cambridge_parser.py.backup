"""
Cambridge Dictionary (剑桥词典) Parser using lxml + requests.

Parses the English-Chinese Simplified dictionary page:
    https://dictionary.cambridge.org/zhs/词典/英语-汉语-简体/{word}

Extracts:
    - headword, part of speech
    - UK & US pronunciations (IPA)
    - definitions (English + Chinese translation)
    - example sentences with translations
    - usage labels & CEFR levels
"""

import re

import requests
from lxml import html
from rich.console import Console
from rich.style import Style
from rich.text import Text

# ── Cambridge Dictionary URL ──────────────────────────────────────────
BASE_URL = "https://dictionary.cambridge.org"
ENTRY_URL = BASE_URL + "/zhs/词典/英语-汉语-简体/{word}"

HEADERS = {
    "User-Agent": (
        "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
        "(KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36"
    ),
    "Accept-Language": "zh-CN,zh;q=0.9,en;q=0.8",
}


# ── Helpers ────────────────────────────────────────────────────────────


def _text(el, default="") -> str:
    """Get cleaned text content of an element."""
    if el is None:
        return default
    text = el.text_content().strip()
    return re.sub(r"\s+", " ", text)


# ── Main Parser ────────────────────────────────────────────────────────


class CambridgeParser:
    """Parse a Cambridge Dictionary (AMP) entry page with lxml."""

    # Known POS labels used for filtering .pos spans
    _KNOWN_POS = {
        "noun",
        "verb",
        "adjective",
        "adverb",
        "pronoun",
        "preposition",
        "conjunction",
        "interjection",
        "exclamation",
        "determiner",
        "number",
        "auxiliary",
        "modal",
        "prefix",
        "suffix",
        "predeterminer",
        "idiom",
        "phrasal verb",
        "phrase",
        "quantifier",
        "abbreviation",
    }

    # Headword values that indicate no real entry was found
    _PLACEHOLDER_HW = {"剑桥词典：英语-中文(简体)翻译", ""}

    def __init__(self, html_content: str, url: str = ""):
        self.tree = html.fromstring(html_content)
        self.root = self.tree
        self.url = url

    @classmethod
    def from_url(cls, word: str, timeout: int = 10) -> "CambridgeParser":
        """Fetch the page and return a parser instance."""
        url = ENTRY_URL.format(word=word.strip().lower())
        resp = requests.get(url, headers=HEADERS, timeout=timeout)
        resp.raise_for_status()
        return cls(resp.text, url=url)

    # ── Headword ──────────────────────────────────────────────────

    def get_headword(self) -> str:
        """Extract the headword from .headword span."""
        # AMP page: <span class="headword hdb tw-bw dhw dpos-h_hw">
        hw = self.root.xpath('//span[contains(@class,"headword")]')
        if hw:
            return _text(hw[0])

        # Fallback: meta og:title
        meta = self.root.xpath('//meta[@property="og:title"]/@content')
        if meta:
            return meta[0].strip()
        return ""

    # ── Part of speech ────────────────────────────────────────────

    def get_part_of_speech(self) -> str:
        """Extract part(s) of speech from .pos.dpos spans."""
        pos_spans = self.root.xpath(
            '//div[contains(@class,"pos-header")]'
            '//span[contains(@class,"pos") and contains(@class,"dpos")]'
        )
        seen: set[str] = set()
        parts: list[str] = []
        for sp in pos_spans:
            t = sp.text_content().strip().lower()
            if t in self._KNOWN_POS and t not in seen:
                seen.add(t)
                parts.append(t)
        return ", ".join(parts)

    # ── Pronunciations ────────────────────────────────────────────

    def get_pronunciation(self) -> dict:
        """Return UK & US IPA pronunciations.

        AMP structure:
            <span class="uk dpron-i">...<span class="pron dpron">/.../</span></span>
            <span class="us dpron-i">...<span class="pron dpron">/.../</span></span>
        """
        result = {"UK": "", "US": ""}

        # UK: inside <span class="uk dpron-i">
        uk_span = self.root.xpath(
            '//span[contains(@class,"uk") and contains(@class,"dpron-i")]'
        )
        if uk_span:
            pron = uk_span[0].xpath('.//span[contains(@class,"pron")]')
            if pron:
                result["UK"] = pron[0].text_content().strip()

        # US: inside <span class="us dpron-i">
        us_span = self.root.xpath(
            '//span[contains(@class,"us") and contains(@class,"dpron-i")]'
        )
        if us_span:
            pron = us_span[0].xpath('.//span[contains(@class,"pron")]')
            if pron:
                result["US"] = pron[0].text_content().strip()

        return result

    # ── Definitions (senses) ──────────────────────────────────────

    def get_senses(self) -> list[dict]:
        """Parse all .def-block elements into sense dicts."""
        senses = []

        # Each meaning is a <div class="def-block ddef_block">
        def_blocks = self.root.xpath('//div[contains(@class,"def-block")]')

        for block in def_blocks:
            sense = self._parse_def_block(block)
            if sense["definition_en"] or sense["definition_zh"]:
                senses.append(sense)

        return senses

    def _parse_def_block(self, block) -> dict:
        """Parse a single .def-block into a sense dict."""
        sense: dict = {
            "level": "",
            "usage": "",
            "definition_en": "",
            "definition_zh": "",
            "examples": [],
        }

        # --- CEFR level from <span class="def-info ddef-info"> (e.g. "A1") ---
        level_spans = block.xpath('.//span[contains(@class,"def-info")]')
        for sp in level_spans:
            t = sp.text_content().strip()
            if re.match(r"^[ABC][12]$", t):
                sense["level"] = t
                break

        # --- English definition from <div class="def ddef_d db"> ---
        def_els = block.xpath(
            './/div[contains(@class,"def") and contains(@class,"ddef_d")]'
        )
        if def_els:
            sense["definition_en"] = _text(def_els[0])

        # --- Chinese translation from <span class="trans dtrans dtrans-se"> ---
        # (the first .trans that is a direct child, before examples)
        trans_els = block.xpath(
            './/span[contains(@class,"trans") and contains(@class,"dtrans-se")]'
        )
        if trans_els:
            sense["definition_zh"] = _text(trans_els[0])

        # --- Usage labels: look for "informal", "old-fashioned" etc. ---
        # In AMP pages these appear as text nodes inside .ddef_h or nearby
        header_el = block.xpath('.//div[contains(@class,"ddef_h")]')
        if header_el:
            header_text = _text(header_el[0])
            for label in (
                "informal",
                "formal",
                "old-fashioned",
                "literary",
                "humorous",
                "slang",
                "approving",
                "disapproving",
                "offensive",
                "mainly uk",
                "mainly us",
            ):
                if label in header_text.lower():
                    sense["usage"] = label
                    break

        # --- Example sentences ---
        # Structure:
        #   <div class="examp dexamp">English sentence. <span class="trans">中文</span></div>
        #   or: <div class="examp dexamp">English.</div>
        #       <span class="trans dtrans dtrans-se hdb break-cj">中文</span>
        examp_divs = block.xpath('.//div[contains(@class,"examp")]')
        for ex_div in examp_divs:
            # Separate English text from embedded Chinese translation
            en_parts = []
            zh_text = ""

            # Text before any child elements
            if ex_div.text:
                en_parts.append(ex_div.text.strip())

            for child in ex_div:
                cls = child.get("class", "")
                if "trans" in cls:
                    zh_text = child.text_content().strip()
                else:
                    if child.tag in ("a", "span", "b", "i", "em", "strong"):
                        text = child.text_content()
                        if child.tail:
                            text += child.tail
                        en_parts.append(re.sub(r"\s+", " ", text).strip())
                    elif child.tail:
                        en_parts.append(child.tail.strip())

            en_text = " ".join(p for p in en_parts if p)
            if not en_text:
                continue

            # If no embedded translation, try following-sibling
            if not zh_text:
                next_span = ex_div.xpath(
                    'following-sibling::span[contains(@class,"trans")][1]'
                )
                if next_span:
                    zh_text = _text(next_span[0])

            if zh_text:
                sense["examples"].append({"en": en_text, "zh": zh_text})

        return sense

    # ── Full parse ────────────────────────────────────────────────

    def parse(self) -> dict:
        """Return the complete parsed entry as a dict."""
        return {
            "word": self.get_headword(),
            "pos": self.get_part_of_speech(),
            "pronunciation": self.get_pronunciation(),
            "senses": self.get_senses(),
            "url": self.url,
        }

    def is_valid_entry(self) -> bool:
        """Check if the page actually contains a dictionary entry."""
        hw = self.get_headword()
        return bool(hw) and hw not in self._PLACEHOLDER_HW


# ── Rich Pretty-print ──────────────────────────────────────────────────

console = Console()

# Style constants
STYLE_WORD = Style(color="cyan", bold=True)
STYLE_POS = Style(color="bright_black", italic=True)
STYLE_UK = Style(color="red")
STYLE_US = Style(color="blue")
STYLE_IPA = Style(color="yellow")
STYLE_LEVEL = Style(color="green", bold=True)
STYLE_USAGE = Style(color="magenta", italic=True)
STYLE_DEF_EN = Style(color="white")
STYLE_DEF_ZH = Style(color="bright_yellow")
STYLE_EX_EN = Style(color="bright_black")
STYLE_EX_ZH = Style(color="yellow")
STYLE_BULLET = Style(color="cyan")
STYLE_INDEX = Style(color="cyan", bold=True)


def _render_entry(entry: dict) -> Text:
    """Render the full entry as a single compact Rich Text (no boxes)."""
    out = Text()

    # ── Headword + POS ──
    out.append(entry["word"], style=STYLE_WORD)
    if entry.get("pos"):
        out.append(f"  {entry['pos']}", style=STYLE_POS)

    # ── Pronunciation ──
    pron = entry.get("pronunciation", {})
    if pron.get("UK") or pron.get("US"):
        out.append("\n")
        if pron.get("UK"):
            out.append("UK ", style=STYLE_UK)
            out.append(pron["UK"], style=STYLE_IPA)
        if pron.get("US"):
            if pron.get("UK"):
                out.append("  ")
            out.append("US ", style=STYLE_US)
            out.append(pron["US"], style=STYLE_IPA)

    # ── Senses ──
    for i, sense in enumerate(entry.get("senses", []), 1):
        out.append(f"\n{i}.  ", style=STYLE_INDEX)

        # Labels: [A1] [informal]
        if sense.get("level"):
            out.append(f"[{sense['level']}]", style=STYLE_LEVEL)
        if sense.get("usage"):
            if sense.get("level"):
                out.append(" ")
            out.append(f"[{sense['usage']}]", style=STYLE_USAGE)
        if sense.get("level") or sense.get("usage"):
            out.append("\n    ")

        # English definition
        if sense.get("definition_en"):
            out.append(sense["definition_en"], style=STYLE_DEF_EN)
            out.append("\n    ")

        # Chinese translation
        if sense.get("definition_zh"):
            out.append(sense["definition_zh"], style=STYLE_DEF_ZH)

        # Examples
        for ex in sense.get("examples", []):
            out.append("\n    • ", style=STYLE_BULLET)
            out.append(ex.get("en", ""), style=STYLE_EX_EN)
            if ex.get("zh"):
                out.append("\n      ", style=STYLE_BULLET)
                out.append(ex["zh"], style=STYLE_EX_ZH)

    return out


def print_entry(entry: dict) -> None:
    """Render a parsed dictionary entry with Rich syntax highlighting."""
    console.print(_render_entry(entry))


# ── CLI ────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    import sys

    word = sys.argv[1] if len(sys.argv) > 1 else "hello"
    try:
        parser = CambridgeParser.from_url(word)
        if not parser.is_valid_entry():
            raise ValueError
    except (requests.HTTPError, ValueError):
        console.print(f"剑桥词典中未找到词条: [bold]{word}[/bold]")
        sys.exit(1)

    entry = parser.parse()
    print_entry(entry)
